# OpenAI Ads API (management + conversions). Get from ads.openai.com → API Dashboard.
OPENAI_ADS_API_KEY=

# LLM provider for the agent (Minimax, Global endpoint, OpenAI-compatible).
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-Text-01

# Oxylabs ChatGPT Scraper API credentials. https://oxylabs.io/products/scraper-api/serp/chatgpt
OXYLABS_USERNAME=
OXYLABS_PASSWORD=

# Oxylabs residential proxy for persona IP stability (optional, defaults to scraper creds above)
OXYLABS_PROXY_USERNAME=
OXYLABS_PROXY_PASSWORD=

# VerseOdin AI Engine Scraper API. Alternative to Oxylabs for ChatGPT/Gemini/Claude scraping.
VERSEODIN_API_KEY=

# Safety: when false, executor creates objects as `paused` and uses validate_only.
# Flip to true ONLY when you intend to spend real money.
ADS_LIVE_MODE=false

# Persona system v2 master key (32 bytes / 64 hex chars). Encrypts credentials
# and session tokens at rest under ~/.openai-ads/personas/<id>/.
# Generate with: pnpm personas --init-keys
PERSONA_MASTER_KEY=

# Where persona data lives. Defaults to ~/.openai-ads.
# OPENAI_ADS_HOME=
