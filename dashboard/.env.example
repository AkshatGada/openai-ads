# ── Email + OTP ──
# Resend API key (https://resend.com) — for sending OTP emails
# Free tier: 100 emails/day
RESEND_API_KEY=

# ── Vercel KV (https://vercel.com/storage/kv) ──
# Auto-configured when you deploy to Vercel with KV enabled.
# For local dev: `pnpm dlx vercel link` then `pnpm dlx vercel env pull`
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ── Google Sheets (optional, for verified emails) ──
# Set GOOGLE_SHEETS_ENABLED=true to use Sheets instead of Vercel KV
GOOGLE_SHEETS_ENABLED=false
# Google Cloud service account email
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# PEM private key (with \n as literal newlines, not actual line breaks)
GOOGLE_PRIVATE_KEY=
# Spreadsheet ID from the URL: https://docs.google.com/spreadsheets/d/<ID>/edit
GOOGLE_SHEET_ID=
